			)
			(justify bottom)
		)
	)
	(gr_text "Colin's Integrated Serial Device\nOpen Hardware\nhttps://colino.net/\n\nModem/printer to Proxy:\nCompatible with Pi 4 and 5\nPi4: modem: /dev/ttyAMA2\n     printer: /dev/ttyAMA3\nPi5: modem: /dev/ttyAMA1\n     printer: /dev/ttyAMA2"
		(at 139.85 134.75 90)
		(layer "F.SilkS")
		(uuid "72b0c2e3-3d7c-499d-bd03-416811930817")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.1875)
			)
			(justify left bottom)
		)
	)
	(gr_text "That's a big-ass PCB for just a few wires\n"
